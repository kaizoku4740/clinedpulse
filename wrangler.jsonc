{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "clinedpulse-speaker-database",
  "main": "src/worker.js",
  "compatibility_date": "2026-06-26",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "clinedpulse-speaker-database",
      "database_id": "50a5424e-f5e7-4f9d-8b0b-bbb5b6356f9c",
      "migrations_dir": "migrations"
    }
  ]
}
